const express = require("express");
const router = express.Router();
const User = require("../models/User");
const bcrypt = require("bcryptjs");
const { Op } = require("sequelize");

// =====================================
// SPECIFIC ROUTES FIRST - PUT THESE AT THE TOP
// =====================================

// Get all users (for admin panel) - THIS MUST COME FIRST
router.get("/all", async (req, res) => {
  try {
    console.log("✅ GET /all route hit!"); // Add this for debugging
    const users = await User.findAll({
      attributes: { exclude: ['password'] },
      order: [['createdAt', 'DESC']]
    });
    
    res.json({ 
      success: true, 
      data: users,
      total: users.length 
    });
  } catch (err) {
    console.error("Error fetching all users:", err);
    res.status(500).json({ success: false, message: "Server error" });
  }
});

// Delete account route
router.post("/delete-account/:id", async (req, res) => {
  try {
    console.log("✅ POST /delete-account/:id route hit!");
    console.log("User ID:", req.params.id);
    console.log("Request body:", req.body);
    
    const { id } = req.params;
    const { password, email } = req.body;
    
    if (!password) {
      return res.status(400).json({ 
        success: false, 
        message: "Password is required" 
      });
    }
    
    const user = await User.findByPk(id);
    
    if (!user) {
      console.log("User not found with ID:", id);
      return res.status(404).json({ 
        success: false, 
        message: "User not found" 
      });
    }
    
    console.log("User found:", user.email);
    
    const isMatch = await bcrypt.compare(password, user.password);
    if (!isMatch) {
      console.log("Password mismatch for user:", id);
      return res.status(400).json({ 
        success: false, 
        message: "Incorrect password. Account deletion failed." 
      });
    }
    
    if (email && user.email !== email) {
      console.log("Email mismatch. Provided:", email, "Actual:", user.email);
      return res.status(400).json({ 
        success: false, 
        message: "Email verification failed." 
      });
    }
    
    const deletedUserEmail = user.email;
    const deletedUserId = user.id;
    
    await user.destroy();
    
    console.log("✅ User deleted successfully:", deletedUserId, deletedUserEmail);
    
    res.json({ 
      success: true, 
      message: "Account successfully deleted" 
    });
    
  } catch (err) {
    console.error("❌ Delete account error:", err);
    res.status(500).json({ 
      success: false, 
      message: "Failed to delete account. Please try again." 
    });
  }
});

// Get user by username
router.get("/by-username/:username", async (req, res) => {
  try {
    const { username } = req.params;
    const decodedUsername = decodeURIComponent(username);
    
    const user = await User.findOne({ 
      where: { 
        [Op.or]: [
          { username: decodedUsername },
          { email: decodedUsername },
          { fullName: decodedUsername }
        ]
      },
      attributes: { exclude: ['password'] }
    });
    
    if (!user) {
      return res.status(404).json({ success: false, message: "User not found" });
    }
    
    res.json({ success: true, user });
  } catch (err) {
    console.error(err);
    res.status(500).json({ success: false, message: "Server error" });
  }
});

